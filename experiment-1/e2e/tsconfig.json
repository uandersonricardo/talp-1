{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-e2e",
    "rootDir": "."
  },
  "include": ["step-definitions/**/*.ts", "support/**/*.ts"],
  "exclude": ["node_modules"]
}
